<Window x:Name="MyWindow" x:Class="FillTheField.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FillTheField"
        mc:Ignorable="d"
        Title="Игра" Height="700" Width="900" KeyDown="MyWindow_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="112.5"/>
            <RowDefinition Height="112.5"/>
            <RowDefinition Height="112.5"/>
            <RowDefinition Height="112.5"/>
            <RowDefinition Height="112.5"/>
            <RowDefinition Height="112.5"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="112.5"/>
            <ColumnDefinition Width="112.5"/>
            <ColumnDefinition Width="112.5"/>
            <ColumnDefinition Width="112.5"/>
            <ColumnDefinition Width="112.5"/>
            <ColumnDefinition Width="112.5"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Rectangle Fill="#FF4B4B4B" Grid.RowSpan="8" SnapsToDevicePixels="True"/>
        <Rectangle Fill="#FF4B4B4B" Grid.Column="7" Grid.RowSpan="8" SnapsToDevicePixels="True"/>
        <Rectangle Fill="#FF4B4B4B" Grid.Row="7" Grid.ColumnSpan="8" SnapsToDevicePixels="True"/>
        <Rectangle Fill="#FF4B4B4B" Grid.ColumnSpan="8" SnapsToDevicePixels="True"/>
        <TextBlock x:Name="EndText" Grid.Column="2" Grid.Row="3" TextWrapping="Wrap" Text="Победа" Grid.RowSpan="2" Grid.ColumnSpan="4" FontSize="72" TextAlignment="Center" Visibility="Hidden" Panel.ZIndex="1"/>
        <Button x:Name="ActionButton" Grid.Column="3" Content="Next" Grid.Row="4" Click="Button_Click" Grid.ColumnSpan="2" Margin="20,20,20,20" FontSize="48" FontWeight="Bold" Panel.ZIndex="1" IsEnabled="False" Visibility="Hidden"/>
        <Grid x:Name="MyGrid" Grid.Column="1" Grid.ColumnSpan="6" Grid.Row="1" Grid.RowSpan="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="112.5"/>
                <RowDefinition Height="112.5"/>
                <RowDefinition Height="112.5"/>
                <RowDefinition Height="112.5"/>
                <RowDefinition Height="112.5"/>
                <RowDefinition Height="112.5"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="112.5"/>
                <ColumnDefinition Width="112.5"/>
                <ColumnDefinition Width="112.5"/>
                <ColumnDefinition Width="112.5"/>
                <ColumnDefinition Width="112.5"/>
                <ColumnDefinition Width="112.5"/>
            </Grid.ColumnDefinitions>
        </Grid>
        <Button x:Name="RestartButton" HorizontalAlignment="Left" Width="92" Height="92" VerticalAlignment="Top" Grid.RowSpan="2" Margin="10,10,0,0" Click="Restart_Click">
            <Button.Content>
                <Image>
                    <Image.Source>
                        <BitmapImage UriSource="./res/images.png"/>
                    </Image.Source>
                </Image>
            </Button.Content>
        </Button>
        <TextBlock x:Name="LevelCounter" Grid.Column="7" Grid.Row="6" TextWrapping="Wrap" Grid.RowSpan="2" FontSize="72" FontWeight="Bold" Foreground="White" TextAlignment="Center"/>


    </Grid>
</Window>
